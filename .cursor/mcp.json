{
  "mcpServers": {
    "personal-notion": {
      "command": "sh",
      "args": [".cursor/run-notion-mcp.sh"]
    },
    "personal-github": {
      "command": "sh",
      "args": [
        "-c",
        "set -a; . .cursor/.env.local; set +a; exec npx -y @modelcontextprotocol/server-github"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    }
  }
}
